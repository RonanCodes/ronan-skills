# Ronan Skills — shared environment variables
#
# Copy this file to ${CLAUDE_PLUGIN_DATA}/.env (Claude Code) or
# ~/.config/ro/.env (other agents). Skills will source it automatically.
#
# ${CLAUDE_PLUGIN_DATA} resolves to a persistent directory provided by Claude
# Code that survives plugin updates. Run `/setup-wizard --tokens` for a guided
# walkthrough.

# --- perplexity-research ---
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_MODEL=sonar

# --- cloudflare-dns ---
# https://dash.cloudflare.com/profile/api-tokens → "Edit zone DNS" template
# Scopes required: Zone:DNS:Edit, Zone:Zone:Read
CLOUDFLARE_API_TOKEN=...

# --- fly-deploy ---
# https://fly.io/user/personal_access_tokens
# Optional — `flyctl auth login` also works. Required for non-interactive use.
FLY_API_TOKEN=...

# --- general ---
OPENAI_API_KEY=sk-...
GITHUB_TOKEN=ghp_...
