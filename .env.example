# ============================================================
# Ronan Skills — Environment Variables Reference
# ============================================================
# This file documents every env var used by skills in this repo.
# It IS committed. Do not put real values here.
#
# Canonical location for real values: ~/.claude/.env
# Skills default to reading ~/.claude/.env. Per-app overrides
# belong in the app's own .env / wrangler secret store.
#
# First-time setup: copy this file's keys into ~/.claude/.env
# and fill them in. `/setup-wizard --tokens` can guide you.
# ============================================================

# ---- AI / LLM providers ----
OPENAI_API_KEY=sk-proj-...                # ad-hoc; fallback for generate-image
GEMINI_API_KEY=AIza...                    # ad-hoc
PERPLEXITY_API_KEY=pplx-...               # perplexity-research
PERPLEXITY_MODEL=sonar                    # default model for perplexity-research

# ---- Audio / Media ----
ELEVENLABS_API_KEY=sk_...                 # tts-elevenlabs, sfx-elevenlabs, music-elevenlabs

# ---- Source control ----
GITHUB_TOKEN=ghp_...                      # general gh CLI use

# ---- Cloudflare (the substrate) ----
# Generate at: https://dash.cloudflare.com/profile/api-tokens
# Template: "Edit Cloudflare Workers" + zone DNS edit
CLOUDFLARE_API_TOKEN=...                  # cf-ship, new-tanstack-app, cloudflare-dns, wrangler
CLOUDFLARE_ACCOUNT_ID=...                 # cf-ship, new-tanstack-app (wrangler.toml)
CLOUDFLARE_ZONE_ID=...                    # cloudflare-dns (per-zone, may override per app)

# ---- Neon (serverless Postgres, for CF Workers via HTTP driver) ----
# Generate at: https://console.neon.tech/app/settings/api-keys
NEON_API_KEY=napi_...                     # neon skill — project / branch management
NEON_ORG_ID=org-...                       # cache — required for /projects endpoint

# ---- Fly.io (legacy / escape hatch) ----
# Prefer ORG-SCOPED tokens (not personal access tokens) — lower blast radius.
# Generate: https://fly.io/dashboard → <org> → Access Tokens → Create Org Token
# flyctl natively reads FLY_API_TOKEN — the fly-deploy skill shadows it at invocation
FLY_ORG_TOKEN='FlyV1 fm2_...'             # fly-deploy — org-scoped token (recommended)
# FLY_API_TOKEN=...                       # fallback: personal access token (wider scope)

# ---- Transactional email ----
# https://resend.com/api-keys — Simplicity Labs workspace
RESEND_API_KEY=re_...                     # app-level email sending

# ---- PostHog (product analytics + flags + A/B) ----
# Generate at: https://eu.posthog.com/settings/user-api-keys
POSTHOG_PERSONAL_API_KEY=phx_...          # personal all-access — CLI / admin
POSTHOG_SIMPLICITY_LABS_API_KEY=phx_...   # project-scoped for Simplicity Labs org
POSTHOG_HOST=https://eu.posthog.com       # management API host (EU)
POSTHOG_INGEST_HOST=https://eu.i.posthog.com  # SDK ingest host (EU)

# ---- Sentry (errors + replay + uptime) ----
# Generate at: https://ronan-connolly.sentry.io/settings/account/api/auth-tokens/
# Scopes: alerts:*, event:*, member:*, org:*, project:*, team:*
SENTRY_AUTH_TOKEN=sntryu_...              # sentry skill, sentry-cli
SENTRY_ORG=ronan-connolly
SENTRY_URL=https://ronan-connolly.sentry.io/
SENTRY_REGION_URL=https://de.sentry.io    # EU region routing for some endpoints

# ---- LinkedIn (official API — posts + userinfo) ----
# App console: https://www.linkedin.com/developers/apps
# Products required: "Sign In with LinkedIn using OpenID Connect" + "Share on LinkedIn"
# Auth → Redirect URLs must include: http://localhost:8765/callback
LINKEDIN_CLIENT_ID=...                    # linkedin skill — from the app's Auth tab
LINKEDIN_CLIENT_SECRET=...                # linkedin skill — from the app's Auth tab
# Filled in by `/ro:linkedin auth` — do not set by hand:
# LINKEDIN_ACCESS_TOKEN=...               # ~60-day TTL; re-run auth when expired
# LINKEDIN_ACCESS_TOKEN_EXPIRES_AT=...    # epoch seconds
# LINKEDIN_PERSON_SUB=...                 # member sub from /v2/userinfo (for urn:li:person:<sub>)

# ---- UptimeRobot (external uptime monitoring) ----
# https://uptimerobot.com/ → My Settings → API Settings
UPTIMEROBOT_API_KEY=u...                  # main key — full CRUD on monitors / alerts
UPTIMEROBOT_READONLY_API_KEY=ur...        # read-only — safe for dashboards, status pages, read queries

# ============================================================
# Per-app (NOT stored globally — generated per project):
#   BETTER_AUTH_SECRET     — 32-byte random, per app
#   BETTER_AUTH_URL        — deployed URL, per app
#   GITHUB_CLIENT_ID/SECRET, GOOGLE_CLIENT_ID/SECRET — OAuth, per app
#   SENTRY_DSN             — Project Settings → Client Keys, per app
# ============================================================
